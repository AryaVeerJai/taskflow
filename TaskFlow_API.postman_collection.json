{
  "info": {
    "name": "TaskFlow API",
    "description": "Complete API collection for TaskFlow — Auth, Tasks, Admin",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "taskflow-api-v1"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api/v1", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [{ "listen": "test", "script": { "exec": [
            "const res = pm.response.json();",
            "if (res.success) {",
            "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
            "  pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
            "  pm.test('Status 201', () => pm.response.to.have.status(201));",
            "}"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"SecurePass1\",\n  \"role\": \"user\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [{ "listen": "test", "script": { "exec": [
            "const res = pm.response.json();",
            "if (res.success) {",
            "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
            "  pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
            "  pm.test('Status 200', () => pm.response.to.have.status(200));",
            "}"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"SecurePass1\"\n}"
            }
          }
        },
        {
          "name": "Get Me",
          "request": { "method": "GET", "url": "{{baseUrl}}/auth/me" }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/update-profile",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"John Updated\"\n}" }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/change-password",
            "body": { "mode": "raw", "raw": "{\n  \"currentPassword\": \"SecurePass1\",\n  \"newPassword\": \"NewSecurePass1\"\n}" }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/refresh-token",
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" }
          }
        },
        {
          "name": "Logout",
          "request": { "method": "POST", "url": "{{baseUrl}}/auth/logout" }
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Get All Tasks",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/tasks?page=1&limit=10&status=todo&priority=high",
              "host": ["{{baseUrl}}"],
              "path": ["tasks"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "status", "value": "todo", "disabled": true },
                { "key": "priority", "value": "high", "disabled": true },
                { "key": "search", "value": "keyword", "disabled": true },
                { "key": "sortBy", "value": "createdAt", "disabled": true },
                { "key": "order", "value": "desc", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Create Task",
          "event": [{ "listen": "test", "script": { "exec": [
            "const res = pm.response.json();",
            "if (res.success) pm.collectionVariables.set('taskId', res.data.task._id);"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/tasks",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Build REST API\",\n  \"description\": \"Implement all CRUD endpoints with auth\",\n  \"status\": \"in-progress\",\n  \"priority\": \"high\",\n  \"dueDate\": \"2025-12-31T00:00:00.000Z\",\n  \"tags\": [\"backend\", \"api\", \"urgent\"]\n}"
            }
          }
        },
        {
          "name": "Get Single Task",
          "request": { "method": "GET", "url": "{{baseUrl}}/tasks/{{taskId}}" }
        },
        {
          "name": "Update Task",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/tasks/{{taskId}}",
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"done\",\n  \"priority\": \"low\"\n}" }
          }
        },
        {
          "name": "Archive Task",
          "request": { "method": "PATCH", "url": "{{baseUrl}}/tasks/{{taskId}}/archive" }
        },
        {
          "name": "Delete Task",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/tasks/{{taskId}}" }
        },
        {
          "name": "Task Stats",
          "request": { "method": "GET", "url": "{{baseUrl}}/tasks/stats" }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Dashboard Stats",
          "request": { "method": "GET", "url": "{{baseUrl}}/admin/stats" }
        },
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/admin/users?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "users"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "role", "value": "user", "disabled": true },
                { "key": "search", "value": "john", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get User By ID",
          "request": { "method": "GET", "url": "{{baseUrl}}/admin/users/{{userId}}" }
        },
        {
          "name": "Toggle User Status",
          "request": { "method": "PATCH", "url": "{{baseUrl}}/admin/users/{{userId}}/toggle-status" }
        },
        {
          "name": "Change User Role",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/admin/users/{{userId}}/role",
            "body": { "mode": "raw", "raw": "{\n  \"role\": \"admin\"\n}" }
          }
        },
        {
          "name": "Get All Tasks (Admin)",
          "request": { "method": "GET", "url": "{{baseUrl}}/admin/tasks" }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": { "method": "GET", "url": "http://localhost:5000/health" }
        }
      ]
    }
  ]
}
